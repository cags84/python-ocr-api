# ==================================
#    SEGURIDAD DEL SERVIDOR
# ==================================
ENVIRONMENT=development
# Opciones permitidas: 'development' o 'production'
# TIP: Usa "production" para habilitar modo estricto y ocultar la documentación `/docs` (Swagger)

ALLOWED_ORIGINS=*
# Dominios autorizados para consultar el API separados por comas. (ej. https://midominio.com, https://app.midominio.com)

# ==================================
#    GOOGLE RECAPTCHA V3
# ==================================
# Obtén tus llaves reales en: https://www.google.com/recaptcha/admin/create
# 
# ⚠️ IMPORTANTE DE SEGURIDAD ⚠️
# NUNCA incluyas tu RECAPTCHA_SECRET_KEY real en el archivo .env si vas a subirlo.
# En lugar de eso, inyéctalo en el Dashboard de tu servidor (Render, Vercel, Railway).
#
# Para probar la app en tu máquina local, puedes copiar este archivo como ".env" 
# e ingresar las "Test Keys" universales de Google que devuelven siempre éxito:

RECAPTCHA_SITE_KEY=6LeIxAcTAAAAAJcZVRqyHh71UMIEGNQ_MXjiZKhI
RECAPTCHA_SECRET_KEY=PON_TU_LLAVE_SECRETA_REAL_AQUI
# (Para pruebas locales usa: 6LeIxAcTAAAAAGG-vFI1TnRWxMZNFuojJ4WifJWe)

RECAPTCHA_SCORE_THRESHOLD=0.5
# El score va de 0.0 (Bot seguro) a 1.0 (Humano seguro). (0.5 es el umbral por defecto recomendado)
